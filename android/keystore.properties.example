# Copy to android/keystore.properties (never commit the real file).
# Generate keystore:
#   keytool -genkey -v -keystore starfall-release.keystore -alias starfall -keyalg RSA -keysize 2048 -validity 10000
storeFile=../starfall-release.keystore
storePassword=CHANGE_ME
keyAlias=starfall
keyPassword=CHANGE_ME
