# config-server environment — generate real values with: npm run gen-keys "<password>"
PORT=8095

# scrypt hash of the admin password (never the raw password)
ADMIN_PASSWORD_HASH=

# HMAC secret for admin session tokens (32 random bytes hex)
SESSION_SECRET=

# AES-256-GCM key for encrypting unpublished drafts at rest (32 bytes / 64 hex)
DRAFT_ENC_KEY=

# Ed25519 private key (PEM, newlines escaped as \n) used to sign published config
CONFIG_SIGN_PRIVATE_KEY=

# Shared secret used when fanning out published config to other game servers
INTERNAL_KEY=

# Restrict which origin may call /admin/* (the deployed admin panel URL). "*" only for local dev.
ADMIN_ORIGIN=*

# Second-factor gate: a long random key the admin panel must send before login is
# even attempted. Without it the login endpoint returns 404. Strongly recommended.
ADMIN_GATE_KEY=

# Comma-separated server endpoints that receive a signed push on every publish
# e.g. https://battle.example.com/internal/config, https://clubs.example.com/internal/config
PUSH_TARGETS=
